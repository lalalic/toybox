<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Toybox uses the local network for remote debugging and automation.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Toybox uses the microphone so you can talk to your toy.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Toybox uses speech recognition to turn your voice into messages for your toy.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
	</array>
</dict>
</plist>
